# API
APP_ENV=development
DOMAINFORGE_API_KEY=
LOG_JSON=false

# Data paths (defaults work for local dev)
DATA_ROOT=./data
CORPUS_DIR=./data/corpus/sop_documents
MANIFEST_PATH=./data/manifests/sop_intent_map.json

# Inference (Phase 4+)
BASE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
OLLAMA_BASE_URL=http://localhost:11434
MOCK_LLM=true

MOCK_LLM=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_ADAPTER_MODEL=domainforge-triage
RETRIEVER_MODE=memory
CHROMA_PATH=./data/indexes/chroma_s1
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
