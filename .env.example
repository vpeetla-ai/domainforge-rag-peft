# API
APP_ENV=development
DOMAINFORGE_API_KEY=
LOG_JSON=false

# Data paths (defaults work for local dev)
DATA_ROOT=./data
CORPUS_DIR=./data/corpus/sop_documents
MANIFEST_PATH=./data/manifests/sop_intent_map.json

# Inference — set MOCK_LLM=false when Ollama models are loaded (see docs/GPU_OLLAMA_PIPELINE.md)
MOCK_LLM=true
# Prefer shared plane when set (aegis-llm-gateway). Else vLLM / Ollama / baseline.
LLM_GATEWAY_URL=
LLM_GATEWAY_API_KEY=
LLM_GATEWAY_TENANT_ID=domainforge-rag-peft
# Educational Path B (optional)
VLLM_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_ADAPTER_MODEL=domainforge-triage
OLLAMA_DPO_ADAPTER_MODEL=domainforge-triage-dpo

# Retrieval
RETRIEVER_MODE=memory
CHROMA_PATH=./data/indexes/chroma_s1
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
